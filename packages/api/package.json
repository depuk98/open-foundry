{
  "name": "@openfoundry/api",
  "version": "0.0.1",
  "description": "Open Foundry GraphQL API server with auto-generated resolvers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist coverage",
    "spec:openapi": "node dist/spec/dump-openapi.js",
    "spec:graphql": "node dist/spec/dump-schema.js",
    "spec:asyncapi": "node dist/spec/dump-asyncapi.js",
    "spec:all": "mkdir -p spec && node dist/spec/dump-openapi.js spec/openapi.yaml && node dist/spec/dump-schema.js spec/schema.graphql && node dist/spec/dump-asyncapi.js spec/asyncapi.yaml"
  },
  "files": [
    "dist"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "@graphql-tools/schema": "^10.0.0",
    "@openfga/sdk": "^0.9.1",
    "@openfoundry/actions": "workspace:*",
    "@openfoundry/engine": "workspace:*",
    "@openfoundry/observability": "workspace:*",
    "@openfoundry/odl": "workspace:*",
    "@openfoundry/security": "workspace:*",
    "@openfoundry/spi": "workspace:*",
    "@openfoundry/storage-memory": "workspace:*",
    "@openfoundry/storage-postgres": "workspace:*",
    "@openfoundry/sync": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "graphql": "^16.10.0",
    "graphql-subscriptions": "^2.0.0",
    "graphql-ws": "^5.16.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "kafkajs": "^2.2.4",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "ws": "^8.18.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
