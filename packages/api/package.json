{
  "name": "@openfoundry/api",
  "version": "0.0.1",
  "description": "Open Foundry GraphQL API server with auto-generated resolvers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist coverage"
  },
  "files": [
    "dist"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "graphql": "^16.10.0",
    "graphql-subscriptions": "^2.0.0",
    "graphql-ws": "^5.16.0",
    "ws": "^8.18.0",
    "@openfoundry/engine": "workspace:*",
    "@openfoundry/actions": "workspace:*",
    "@openfoundry/security": "workspace:*",
    "@openfoundry/odl": "workspace:*",
    "@openfoundry/observability": "workspace:*",
    "@openfoundry/spi": "workspace:*",
    "@openfoundry/storage-memory": "workspace:*",
    "@openfoundry/storage-postgres": "workspace:*",
    "@openfga/sdk": "^0.9.1",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/cors": "^2.8.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
