{
  "name": "@openfoundry/security",
  "version": "0.0.1",
  "private": true,
  "description": "OIDC authentication and authorization for the Open Foundry platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@openfga/sdk": "^0.9.1",
    "@openfoundry/observability": "workspace:*",
    "@openfoundry/spi": "workspace:*",
    "jose": "^6.0.0"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
