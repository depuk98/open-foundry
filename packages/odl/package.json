{
  "name": "@openfoundry/odl",
  "version": "0.1.0",
  "description": "Open Foundry ODL (Ontology Definition Language) parser",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist coverage"
  },
  "bin": {
    "odl": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "commander": "^14.0.3",
    "graphql": "^16.10.0"
  },
  "devDependencies": {
    "@openfoundry/spi": "workspace:*",
    "@types/node": "^22.0.0",
    "vitest": "^3.0.0"
  }
}
