# OSINT Domain Pack — Event ObjectType
#
# Models discrete events: battles, airstrikes, protests, diplomatic
# meetings, humanitarian crises. Links to participants, locations,
# equipment, and source reports.

extend schema @namespace(name: "osint", version: "0.2.0")

type Event implements Identifiable & Auditable & Locatable & Temporal @objectType {
  id: ID! @primary
  createdAt: DateTime! @readonly
  createdBy: String! @readonly
  updatedAt: DateTime! @readonly
  updatedBy: String! @readonly

  eventDate: DateTime! @indexed
  eventEndDate: DateTime
  validFrom: DateTime
  validTo: DateTime

  type: EventType! @indexed
  subtype: String @indexed
  description: String! @searchable

  location: GeoPoint!
  locationName: String! @searchable
  locationPrecision: String
  country: Country! @indexed
  region: String @indexed

  fatalities: Int
  fatalitiesCivilian: Int
  casualtiesWounded: Int
  displacedPersons: Int
  casualtyConfidence: ConfidenceLevel

  attributedTo: Organization @link(type: "EventAttributedToOrg", direction: OUTBOUND)
  attributionConfidence: ConfidenceLevel
  claimedBy: Organization @link(type: "EventClaimedByOrg", direction: OUTBOUND)
  attributionNarrative: String @searchable

  participants: [Person!]! @link(type: "PersonInvolvedInEvent", direction: INBOUND, history: true)
  participantOrgs: [Organization!]! @link(type: "OrgInvolvedInEvent", direction: INBOUND, history: true)

  equipmentUsed: [Equipment!]! @link(type: "EquipmentUsedInEvent", direction: INBOUND, history: true)

  sourceReports: [IntelReport!]! @link(type: "ReportedEvent", direction: INBOUND, history: true)
  reportCount: Int @computed(fn: "countLinks", args: { type: "ReportedEvent" })

  geolocationVerified: Boolean
  geolocationProof: [URI!]
  verifiedByAnalyst: String

  impactAssessment: String @searchable
  infrastructureDamaged: [Location!]! @link(type: "InfrastructureDamagedInEvent", direction: OUTBOUND)
}
