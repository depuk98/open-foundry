# OSINT Domain Pack — Enumerations
#
# Covers source classification, event types, organization types,
# equipment categories, credibility ratings, and country codes.

extend schema @namespace(name: "osint", version: "0.2.0")

enum IntelSource {
  TWITTER
  TELEGRAM
  RSS
  ACLED
  LIVEUAMAP
  ISW
  BELLINGCAT
  CUSTOM
}

enum SourceCategory {
  CONFLICT_MONITOR
  GEOSPATIAL_ANALYST
  ARMS_IDENTIFIER
