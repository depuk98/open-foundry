  INSTITUTIONAL
  INVESTIGATIVE_JOURNALISM
  ACADEMIC
  GOVERNMENT_OFFICIAL
  NEWS_WIRE
  STATE_MEDIA
  ACTIVIST
  UNKNOWN
}

enum CredibilityRating {
  VERIFIED
  LIKELY
  POSSIBLE
  DOUBTFUL
  DISPROVEN
  UNEVALUATED
}

enum IntelReportStatus {
