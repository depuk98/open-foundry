.git
.github
.avril
.claude
.env
.env.*
!.env.example
node_modules
**/node_modules
**/dist
# Go CEL sidecar — not a pnpm workspace member (no package.json), so the
# TypeScript service images (context = repo root) never need it. Its own image
# builds from packages/cel-evaluator as a separate context. Excluding it keeps
# the committed ~22MB Go binary out of every Node image.
packages/cel-evaluator
**/*.tsbuildinfo
**/*.test.ts
**/__tests__
**/coverage
# Exclude tests/ and tools/ source — only package.json is needed in Docker so
# pnpm sees the full workspace and --frozen-lockfile works.
tests/*/src
tests/*/.turbo
tests/*/.gitkeep
tests/*/*.ts
tools/*/src
tools/*/.turbo
tools/*/.gitkeep
tools/*/*.ts
docs/
*.md
LICENSE
.turbo
.vscode
.idea
deploy/
