{
  "name": "@openfoundry/pilot-scenarios",
  "version": "0.0.1",
  "description": "End-to-end pilot scenario tests (MVP Section 7)",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:verbose": "vitest run --reporter=verbose",
    "clean": "rm -rf dist coverage"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "@openfoundry/spi": "workspace:*",
    "@openfoundry/odl": "workspace:*",
    "@openfoundry/storage-memory": "workspace:*",
    "@openfoundry/actions": "workspace:*",
    "@openfoundry/security": "workspace:*",
    "@openfoundry/sync": "workspace:*",
    "@openfoundry/api": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  }
}
