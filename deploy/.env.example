# ─── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_DB=openfoundry
POSTGRES_USER=openfoundry
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# ─── Redpanda (Kafka-compatible) ────────────────────────────────
REDPANDA_PORT=19092

# ─── Redis (distributed rate limiting) ─────────────────────────
REDIS_PORT=6379

# ─── OpenFGA ─────────────────────────────────────────────────────
OPENFGA_PORT=8280
OPENFGA_STORE_ID=

# ─── Keycloak ────────────────────────────────────────────────────
KEYCLOAK_PORT=8180
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme
KEYCLOAK_REALM=openfoundry

# ─── Debezium ────────────────────────────────────────────────────
DEBEZIUM_PORT=8083

# ─── OpenTelemetry Collector ─────────────────────────────────────
OTEL_PORT=4317

# ─── CEL Evaluator (gRPC) ───────────────────────────────────────
CEL_PORT=50051

# ─── API Gateway ─────────────────────────────────────────────────
API_PORT=4000

# ─── Build ──────────────────────────────────────────────────────
# Git revision stamped into Docker image labels.
# Set automatically by: GIT_REVISION=$(git rev-parse HEAD) docker compose up --build
# GIT_REVISION=

# ─── Domain Packs ────────────────────────────────────────────────
# Comma-separated list of pack names to activate (omit for all discovered packs).
# DOMAIN_PACKS=core,nhs-acute

# External pack directories (colon-separated on POSIX, semicolon on Windows).
# Each entry may be a parent directory containing pack subdirectories, or a
# direct path to a single pack directory (one that contains pack.yaml).
# Inside the container these resolve to the mount point below.
# DOMAIN_PACKS_EXTRA_DIRS=/external-packs

# Host path mounted into the api-gateway container at /external-packs.
# May be a parent dir (subdirs scanned) or a direct pack dir.
# DOMAIN_PACKS_HOST_DIR=../../silmaril-dp-rce
