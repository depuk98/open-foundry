# ─── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_DB=openfoundry
POSTGRES_USER=openfoundry
POSTGRES_PASSWORD=openfoundry_dev
POSTGRES_PORT=5432

# ─── Redpanda (Kafka-compatible) ────────────────────────────────
REDPANDA_PORT=19092

# ─── OpenFGA ─────────────────────────────────────────────────────
OPENFGA_PORT=8080
OPENFGA_STORE_ID=

# ─── Keycloak ────────────────────────────────────────────────────
KEYCLOAK_PORT=8180
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=openfoundry

# ─── Debezium ────────────────────────────────────────────────────
DEBEZIUM_PORT=8083

# ─── OpenTelemetry Collector ─────────────────────────────────────
OTEL_PORT=4317

# ─── CEL Evaluator (gRPC) ───────────────────────────────────────
CEL_PORT=50051

# ─── API Gateway ─────────────────────────────────────────────────
API_PORT=4000
